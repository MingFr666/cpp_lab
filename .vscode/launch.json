{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "cmake",
      "type": "cppdbg",
      "request": "launch",
      "program": "${command:cmake.launchTargetPath}",
      "args": [],
      "cwd": "${workspaceFolder}/install",
      "stopAtEntry": false,
      "externalConsole": false,
      "MIMode": "gdb",
      "miDebuggerPath": "/usr/bin/gdb",
      "setupCommands": [
        {
          "description": "Enable pretty printing",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        },
        {
          "description": "Break at user main, skip libc startup",
          "text": "-break-insert -t main",
          "ignoreFailures": true
        },
        {
          "description": "Skip glibc startup files",
          "text": "skip file */csu/*",
          "ignoreFailures": true
        },
        {
          "description": "Skip glibc sysdeps files",
          "text": "skip file */sysdeps/*",
          "ignoreFailures": true
        },
        {
          "description": "Skip libc startup function",
          "text": "skip function __libc_start_call_main",
          "ignoreFailures": true
        },
        {
          "description": "Skip libc entry function",
          "text": "skip function __libc_start_main",
          "ignoreFailures": true
        }
      ]
    }
  ]
}
